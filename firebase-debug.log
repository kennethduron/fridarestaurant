[debug] [2026-03-08T23:11:28.258Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/casabrava2-400d3/rulesets {"name":"projects/casabrava2-400d3/rulesets/cbcdaf07-c137-4fe1-b911-5f88b71f368d","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isStaff() {\n      return isSignedIn()\n        && exists(/databases/$(database)/documents/staff/$(request.auth.uid))\n        && get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.active == true\n        && (get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role in ['admin', 'agent', 'representative']);\n    }\n\n    function validOrderCreate() {\n      return request.resource.data.keys().hasOnly([\n          'displayId', 'language', 'customer', 'items', 'total', 'payment', 'invoice', 'status', 'createdAt', 'updatedAt', 'updatedBy'\n        ])\n        && request.resource.data.customer is map\n        && request.resource.data.customer.keys().hasOnly(['name', 'phone', 'comments', 'pickup'])\n        && request.resource.data.customer.name is string\n        && request.resource.data.customer.phone is string\n        && (!('comments' in request.resource.data.customer) || request.resource.data.customer.comments is string)\n        && (!('pickup' in request.resource.data.customer) || request.resource.data.customer.pickup is bool)\n        && request.resource.data.items is list\n        && request.resource.data.total is number\n        && (!('payment' in request.resource.data)\n          || (\n            request.resource.data.payment is map\n            && request.resource.data.payment.keys().hasOnly(['method', 'status', 'provider', 'checkoutUrl', 'cardLast4', 'transactionId', 'paypalOrderId'])\n            && request.resource.data.payment.method is string\n            && request.resource.data.payment.status is string\n            && request.resource.data.payment.provider is string\n            && request.resource.data.payment.checkoutUrl is string\n            && request.resource.data.payment.cardLast4 is string\n            && request.resource.data.payment.transactionId is string\n            && request.resource.data.payment.paypalOrderId is string\n          ))\n        && (!('invoice' in request.resource.data)\n          || (\n            request.resource.data.invoice is map\n            && request.resource.data.invoice.keys().hasOnly([\n              'billingName', 'billingRTN', 'invoiceNumber', 'notes', 'hasExoneration', 'exemptionRegister', 'exemptOrderNumber', 'sagRegister'\n            ])\n            && request.resource.data.invoice.billingName is string\n            && request.resource.data.invoice.billingRTN is string\n            && request.resource.data.invoice.invoiceNumber is string\n            && request.resource.data.invoice.notes is string\n            && request.resource.data.invoice.hasExoneration is bool\n            && request.resource.data.invoice.exemptionRegister is string\n            && request.resource.data.invoice.exemptOrderNumber is string\n            && request.resource.data.invoice.sagRegister is string\n          ))\n        && request.resource.data.status == 'pending';\n    }\n\n    function validReservationCreate() {\n      return request.resource.data.keys().hasOnly([\n          'name', 'phone', 'email', 'date', 'time', 'party', 'occasion', 'allergies', 'notes', 'language', 'createdAt'\n        ])\n        && request.resource.data.name is string\n        && request.resource.data.phone is string\n        && request.resource.data.party is number;\n    }\n\n    match /orders/{orderId} {\n      allow create: if validOrderCreate();\n      allow get: if true;\n      allow list: if isStaff();\n      allow update: if isStaff();\n      allow delete: if false;\n    }\n\n    match /reservations/{reservationId} {\n      allow create: if validReservationCreate();\n      allow read: if isStaff();\n      allow update: if isStaff();\n      allow delete: if false;\n    }\n\n    match /staff/{userId} {\n      allow read: if isSignedIn() && request.auth.uid == userId;\n      allow write: if false;\n    }\n\n    match /usernames/{username} {\n      allow get: if true;\n      allow list: if false;\n      allow create, update, delete: if false;\n    }\n\n    match /settings/{settingId} {\n      allow get: if isStaff();\n      allow list: if false;\n      allow create, update: if isStaff();\n      allow delete: if false;\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-03-08T23:11:23.295471Z","metadata":{"services":["cloud.firestore"]}}
